# ===========================================================================
# Sites Manager — קובץ דוגמה למשתני סביבה
# העתק לקובץ .env ומלא ערכים אמיתיים:   cp .env.example .env
# ===========================================================================

# --- מסד נתונים ---------------------------------------------------------------
# פיתוח מקומי (ברירת מחדל) — SQLite, אפס התקנה:
DATABASE_URL="file:./dev.db"
#
# פרודקשן — PostgreSQL. כדי לעבור:
#   1. שנה ב-prisma/schema.prisma את  provider = "sqlite"  ל-  provider = "postgresql"
#   2. החלף את DATABASE_URL כאן ב-connection string של פוסטגרס:
# DATABASE_URL="postgresql://user:password@localhost:5432/sites_manager?schema=public"

# --- NextAuth (אימות) --------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
# צור סוד חזק:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_BASE64_SECRET"

# --- המשתמש היחיד (נוצר בזריעת הנתונים) -------------------------------------
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe!123"
ADMIN_NAME="מנהל המערכת"

# --- מפתח הצפנה לכספת הסיסמאות (AES-256-GCM) ---------------------------------
# חייב להיות 64 תווי hex (= 32 בייט). צור:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# אזהרה: אם תאבד מפתח זה — לא ניתן יהיה לפענח את הסיסמאות השמורות.
ENCRYPTION_KEY="REPLACE_WITH_64_HEX_CHARS"

# --- Cron (בדיקת חידושים יומית) ----------------------------------------------
# סוד שמגן על הנתיב /api/cron מהרצה לא מורשית.
CRON_SECRET="REPLACE_WITH_RANDOM_SECRET"
# כתובת האפליקציה (לשימוש הסקריפט העצמאי של node-cron):
APP_URL="http://localhost:3000"

# --- שליחת אימייל ------------------------------------------------------------
# אופציה א': SMTP רגיל (Gmail / Mailgun / כל ספק). אם ריק — מיילים יודפסו לקונסול בלבד.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"            # true עבור פורט 465
SMTP_USER=""
SMTP_PASS=""
# אופציה ב': Resend (אם מוגדר, יקבל עדיפות על SMTP):
RESEND_API_KEY=""
# כתובת השולח והיעד להתראות:
EMAIL_FROM="Sites Manager <no-reply@example.com>"
EMAIL_TO="me@example.com"

# --- הגדרות מנוע ההתראות -----------------------------------------------------
# ימים לפני חידוש שבהם תישלח התראת מייל (מופרד בפסיקים):
REMINDER_THRESHOLDS_DAYS="30,14,7"
# התראה כשתוקף SSL נשאר פחות מ-X ימים:
SSL_WARN_DAYS="14"
